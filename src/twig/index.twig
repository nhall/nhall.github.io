<!doctype html>
<html lang="en-US">
	<head>
		<meta charset="utf-8">
		<title>{{ name }} — {{ title }}</title>
		<meta name="description" content="{{ intro }}">
		<meta name="viewport" content="width=device-width, initial-scale=1">

		<meta property="og:title" content="{{ name }} — {{ title }}">
		<meta property="og:type" content="profile">
		<meta property="og:description" content="{{ intro }}">
		<meta property="og:url" content="https://nhall.github.io/">

		<meta name="theme-color" content="#f0ece4" media="(prefers-color-scheme: light)">
		<meta name="theme-color" content="#1a1a1a" media="(prefers-color-scheme: dark)">
		<link rel="stylesheet" href="css/site.css">
	</head>
	<body>

		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Person",
				"name": "{{ name }}",
				"alternateName": "Nick Hall",
				"jobTitle": "{{ title }}",
				"description": "{{ intro }}",
				"url": "https://nhall.github.io/",
				"sameAs": [{% set comma = false %}{% for link in links %}{% if link.name != 'Resume' %}{% if comma %},{% endif %}"{{ link.url }}"{% set comma = true %}{% endif %}{% endfor %}]
			}
		</script>

		<div class="splash">
			<div class="splash_grain" aria-hidden="true"></div>
			<a class="skip_link focusable" href="#nav">Skip to navigation</a>
			<main class="main">
				<h1 class="main_name">{{ name }}</h1>
				<p class="main_description">{{ intro }}</p>
				<nav class="nav" id="nav" aria-label="Social links">
					<h2 class="nav_title">Connect</h2>
					<ul class="nav_list">
						{% for link in links %}
						<li class="nav_item">
							<a class="nav_link" href="{{ link.url }}"{% if link.name != 'Resume' %} target="_blank" rel="noopener nofollow noreferrer"{% endif %}>{{ link.name }}</a>
						</li>
						{% endfor %}
					</ul>
				</nav>
			</main>
			<button class="animation_toggle" type="button" aria-pressed="true" aria-label="Background animation">
				<svg class="animation_toggle_icon animation_toggle_icon--pause" aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
				<svg class="animation_toggle_icon animation_toggle_icon--play" aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><polygon points="6,4 20,12 6,20"/></svg>
			</button>
		</div>

		<script>
			(function () {
				var btn = document.querySelector('.animation_toggle');
				var splash = document.querySelector('.splash');
				var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

				function pause() {
					splash.classList.add('splash--paused');
					btn.setAttribute('aria-pressed', 'false');
				}

				function play() {
					splash.classList.remove('splash--paused');
					btn.setAttribute('aria-pressed', 'true');
				}

				if (prefersReducedMotion.matches) {
					pause();
				}

				prefersReducedMotion.addEventListener('change', function (e) {
					if (e.matches) {
						pause();
					} else {
						play();
					}
				});

				btn.addEventListener('click', function () {
					if (splash.classList.contains('splash--paused')) {
						play();
					} else {
						pause();
					}
				});
			})();
		</script>
		<script data-goatcounter="https://nhall.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
	</body>
</html>
